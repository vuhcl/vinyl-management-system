# ============================================================
# vinyl_collector_ai/.env
#
# API credentials for vinyl condition grader, VinylIQ, recommender, etc.
# NEVER commit this file to git.
# Copy this template, fill in your credentials, save as .env
# ============================================================

# ------------------------------------------------------------
# Discogs API — personal access token (required for most scripts)
#
# Generate at: https://www.discogs.com/settings/developers
# Use either name below (same value; grader/README uses DISCOGS_TOKEN).
# ------------------------------------------------------------
DISCOGS_TOKEN=your_discogs_personal_token_here
# Optional alias (if set, takes precedence over DISCOGS_TOKEN when both exist):
# DISCOGS_USER_TOKEN=

# ------------------------------------------------------------
# Discogs OAuth 1.0a app (optional — alternative to personal token)
#
# Register at: https://www.discogs.com/settings/developers
# Set a callback URL that matches DISCOGS_OAUTH_CALLBACK (e.g. http://127.0.0.1:8765/callback).
# One-time: PYTHONPATH=. python price_estimator/scripts/collect_marketplace_stats.py --oauth-login
# Then add the printed DISCOGS_OAUTH_TOKEN* lines below.
# ------------------------------------------------------------
# DISCOGS_CONSUMER_KEY=
# DISCOGS_CONSUMER_SECRET=
# DISCOGS_OAUTH_TOKEN=
# DISCOGS_OAUTH_TOKEN_SECRET=
# DISCOGS_OAUTH_CALLBACK=http://127.0.0.1:8765/callback
# DISCOGS_REQUEST_TOKEN_URL=https://api.discogs.com/oauth/request_token
# DISCOGS_ACCESS_TOKEN_URL=https://api.discogs.com/oauth/access_token
# DISCOGS_AUTHORIZE_URL=https://www.discogs.com/oauth/authorize

# ------------------------------------------------------------
# Discogs sale history (Botasaurus web scrape — logged-in Chrome profile)
#
# Path to a dedicated Chrome user-data directory where you have signed into
# Discogs in the browser (create once with collect_sale_history_botasaurus.py --no-headless).
# See price_estimator/scripts/collect_sale_history_botasaurus.py --help
# ------------------------------------------------------------
# DISCOGS_SALE_HISTORY_BROWSER_PROFILE=/absolute/path/to/chrome-profile-discogs

# ------------------------------------------------------------
# eBay Developer API
# Register at: https://developer.ebay.com
# Create an app at: https://developer.ebay.com/my/keys
# Use the "Sandbox" keys for testing, "Production" for real data
# ------------------------------------------------------------
EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here

