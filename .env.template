# ------------------------------------------------------------
# MLflow + Google Cloud (optional)
#
# Grader: reduce remote noise with ``grader/configs/grader.yaml`` keys
# ``mlflow.enabled`` / ``mlflow.log_artifacts``, or CLI
# ``python -m grader.src.pipeline train --mlflow-no-artifacts`` / ``--no-mlflow``.
#
# Tracking server URL — training, retention scripts (e.g. prune_mlflow_model_versions).
# Local: http://127.0.0.1:5000   Remote: https://mlflow.your-domain.example
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
#
# Optional: override where ``transformer_tune`` logs sweep runs (default: local
# SQLite from grader.yaml ``tuning_tracking_uri_fallback``).
# MLFLOW_TUNING_TRACKING_URI=sqlite:///grader/experiments/mlflow_tuning.db
#
# When MLFLOW_TRACKING_URI points at a remote server whose default artifact
# root is gs://…, set a service account key so uploads do not use anonymous creds:
# ------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json