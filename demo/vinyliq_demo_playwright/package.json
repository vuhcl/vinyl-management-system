{
  "name": "vinyliq-demo-playwright",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright TypeScript spec that drives the vinyl management system demo (release-page price estimate + seller-page condition grading) and records a 2-minute video.",
  "scripts": {
    "test": "playwright test --project=demo",
    "test:ci": "DEMO_CATALOG_UX=0 DEMO_SKIP_HOLDS=1 DEMO_VIDEO_CHAPTERS=0 playwright test --project=demo",
    "test:show": "playwright test --project=demo --headed",
    "assist:pitch": "playwright test --project=pitch-assist",
    "install-browsers": "playwright install chromium",
    "warm-profile": "WARM_PROFILE=1 playwright test tests/warm_profile.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
